{
  "rules": {
    "userData": {
      "$uid": {
        ".write": "$uid === auth.uid",
        "profile": {
          ".read": "$uid === auth.uid",
          ".indexOn": ["email"]
        },
        "notifications": {
          ".read": "$uid === auth.uid",
          ".indexOn": ["createdAt", "read"]
        },
        "sharedLists": {
          ".read": "auth != null",
          ".indexOn": ["ownerId"]
        },
        "shoppingLists": {
          ".read": "auth != null",
          ".indexOn": ["name"]
        }
      }
    },
    "shoppingLists": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "sharedLists": {
      ".read": "auth != null",
      "$listId": {
        "$userId": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      }
    },
    "invitations": {
      "$invitationId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    }
  }
}
