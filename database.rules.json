{
  "rules": {
    "userData": {
      "$uid": {
        ".read": "auth != null",
        ".write": "$uid === auth.uid",
        "profile": {
          ".write": "$uid === auth.uid",
          ".indexOn": ["email"]
        },
        "notifications": {
          ".read": "$uid === auth.uid",
          ".write": "$uid === auth.uid",
          ".indexOn": ["createdAt", "read"]
        },
        "sharedLists": {
          ".indexOn": ["ownerId"],
          "$listId": {
            "members": {
              ".write": "$uid === auth.uid"
            }
          }
        },
        "shoppingLists": {
          "$listId": {
            "pickedItems": {
              ".write": "$uid === auth.uid || root.child('userData/' + auth.uid + '/sharedLists/' + $listId).exists()"
            }
          },
          ".indexOn": ["name"]
        },
        "sharedListPickedItems": {
          "$listId": {
            ".write": "auth != null"
          }
        }
      }
    },
    "sharedPickedItems": {
      "$listId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "shoppingLists": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "sharedLists": {
      ".read": "auth != null",
      "$listId": {
        "$userId": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      }
    },
    "invitations": {
      "$invitationId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    }
  }
}